generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  UNASSIGNED
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id              String          @id @default(uuid()) @db.Uuid
  name            String
  email           String          @unique
  passwordHash    String
  role            UserRole        @default(USER)
  tickets         Ticket[]
  assignedTickets Ticket[]        @relation("TicketAssignment")
  messages        TicketMessage[]
  ticketReads     TicketRead[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Ticket {
  id              String          @id @default(uuid()) @db.Uuid
  title           String
  description     String
  status          TicketStatus    @default(OPEN)
  priority        TicketPriority  @default(UNASSIGNED)
  userId          String          @db.Uuid
  assignedAdminId String?         @db.Uuid
  assignedAt      DateTime?
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin   User?           @relation("TicketAssignment", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  analysis        TicketAnalysis?
  messages        TicketMessage[]
  reads           TicketRead[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([assignedAdminId])
  @@index([status])
}

model TicketAnalysis {
  id        String         @id @default(uuid()) @db.Uuid
  ticketId  String         @unique @db.Uuid
  ticket    Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  category  String
  priority  TicketPriority
  summary   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TicketMessage {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @db.Uuid
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String   @db.Uuid
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@index([senderId])
}

model TicketRead {
  id         String   @id @default(uuid()) @db.Uuid
  ticketId   String   @db.Uuid
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([ticketId, userId])
  @@index([userId])
}
